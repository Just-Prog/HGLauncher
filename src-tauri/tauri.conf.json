{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hglauncher",
  "version": "0.1.0",
  "identifier": "io.github.justprog.yetanotherhyglauncher",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "YAHGL - Yet Another Hypergryph Games Launcher",
        "width": 1280,
        "height": 720,
        "decorations": false,
        "transparent": true,
        "center": true,
        "minHeight": 720,
        "minWidth": 1280,
        "maxHeight": 720,
        "maxWidth": 1280,
        "windowEffects": {
          "effects": ["hudWindow", "mica", "acrylic"],
          "radius": 8
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
